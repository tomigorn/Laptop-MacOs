# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes
.fseventsd
.DocumentRevisions-V100
.TemporaryItems

# ── Editors / IDEs ───────────────────────────────────────────────────────────
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-*

# ── Claude Code ──────────────────────────────────────────────────────────────
# Local, machine-specific settings (also covered by ~/.gitignore_global).
.claude/settings.local.json

# ── Secrets & credentials — never commit real ones ───────────────────────────
# NOTE: the placeholder keys under multiple-git-accounts/.ssh/ are intentional
# template files and stay tracked (.gitignore doesn't untrack already-tracked
# files). These rules stop REAL keys/secrets from being added by accident.
*.pem
*.key
*.p12
*.pfx
id_rsa
id_dsa
id_ecdsa
id_ed25519
*_rsa
*_dsa
*_ecdsa
*_ed25519
!*.pub
.env
.env.*
*.secret
secrets.*
credentials.json
.netrc

# ── Logs / runtime cruft ─────────────────────────────────────────────────────
*.log
tmp/
*.tmp
